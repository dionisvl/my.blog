#!/usr/bin/env bash

# See https://docs.docker.com/compose/environment-variables/#the-env-file

# Nginx Gateway
SERVER_NAME=example.com
GATEWAY_HOTS_PORT=80
GATEWAY_DOCKER_PORT=80

# App
APP_ENV=prod
APP_LOCATION=/var/www/example.com
APP_STORAGE_LOCATION=/var/www/example.com/storage
#APP_DEBUG=1
DOCKER_REGISTRY_SERVER="IP:PORT"
PHP_IDE_CONFIG=serverName=${SERVER_NAME}
CERTBOT_DOMAINS=example.com,example.com
CERTBOT_EMAIL=myemail@gmail.com
DOMAIN_BASE=example.com
CANONICAL_DOMAIN=example.com
ACME_EMAIL=admin@example.com
DASHBOARD_AUTH="<admin>:<hashed-password>"

# PostgreSQL
POSTGRES_DB=my_blog
POSTGRES_USER=app
POSTGRES_PASSWORD=***
# DB
DB_HOST=postgres
DB_USER=app
DB_PASSWORD=***
DB_NAME=my_blog
DB_PORT_EXTERNAL=54321

# Mailer
MAILER_HOST=smtp.yandex.ru
MAILER_PORT=465
MAILER_USER=info@example.com
MAILER_PASSWORD=secret
MAILER_ENCRYPTION=""
MAILER_FROM_EMAIL=info@example.com

SENTRY_DSN=https://xxxxxxxxxx.ingest.sentry.io/6xxx

# Victoria Logs & vmauth
VMAUTH_ADMIN_USER=***
VMAUTH_ADMIN_PASS=***
VMAUTH_READONLY_USER=***
VMAUTH_READONLY_PASS=***

# Jaeger
JAEGER_AUTH=admin:***(htpasswd)

# Grafana Monitoring Stack
GRAFANA_ADMIN_USER=xxx
GRAFANA_ADMIN_PASSWORD=xxx

# BasicAuth (htpasswd -nB username, escape $ as $$)
PROMETHEUS_AUTH="user:pass"
GRAFANA_AUTH="user:pass"
ALERTMANAGER_AUTH="user:pass"
